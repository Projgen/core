{
  "name": "@projgen/cli",
  "version": "2.5.0",
  "description": "A project scaffolding cli tool",
  "license": "MIT",
  "author": "LorisRue",
  "keywords": [
    "cli"
  ],
  "type": "module",
  "main": "./dist/cli/main.js",
  "bin": {
    "projgen": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Projgen/core_v2.git"
  },
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "build": "npx rimraf dist && tsc --outDir dist && tsc-alias && tsx src/scripts/schema.ts > template.schema.json",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli/main.js",
    "test": "vitest run src/",
    "test:coverage": "vitest run src/ --coverage",
    "test:watch": "vitest watch src/",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "cross-spawn": "^7.0.6",
    "inquirer": "^13.4.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  }
}
